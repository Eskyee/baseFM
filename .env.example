# baseFM Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# SUPABASE
# Get these from: https://supabase.com → Project Settings → API
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# MUX
# Get these from: https://dashboard.mux.com → Settings → Access Tokens
# ============================================
MUX_TOKEN_ID=xxxxx
MUX_TOKEN_SECRET=xxxxx
MUX_WEBHOOK_SECRET=xxxxx

# ============================================
# BASE NETWORK
# ============================================
NEXT_PUBLIC_BASE_CHAIN_ID=8453
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# ============================================
# ONCHAINKIT (Optional)
# Get from: https://portal.cdp.coinbase.com
# ============================================
NEXT_PUBLIC_ONCHAINKIT_API_KEY=

# ============================================
# PUSH NOTIFICATIONS (Optional)
# Generate with: npx web-push generate-vapid-keys
# ============================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ============================================
# APP CONFIG
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# BANKR SDK
# Server-side only — BANKR_PRIVATE_KEY must never reach client
# ============================================
NEXT_PUBLIC_BANKR_API_KEY=
BANKR_PRIVATE_KEY=

# ============================================
# TOKEN CONTRACTS (Base)
# ============================================
RAVECULTURE_TOKEN_ADDRESS=
RAVECULTURE_ACCESS_CONTRACT=
RAVECULTURE_IDENTITY_CONTRACT=

# ============================================
# CLANKER (Token-gated Chat)
# ============================================
NEXT_PUBLIC_CLANKER_KEY=

# ============================================
# ADMIN
# Comma-separated list of admin wallet addresses
# ============================================
ADMIN_WALLET_ADDRESS=
